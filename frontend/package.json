{
  "name": "dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node set-env.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --runner=vitest",
    "test:run": "vitest run --config vitest-base.config.ts",
    "test:watch": "vitest --config vitest-base.config.ts",
    "serve:ssr:dashboard": "node dist/dashboard/server/server.mjs",
    "clean": "ng cache clean"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/animations": "^21.2.0-next.1",
    "@angular/cdk": "^21.0.6",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.6",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@angular/ssr": "^21.0.5",
    "@supabase/supabase-js": "^2.99.2",
    "@types/crypto-js": "^4.2.2",
    "@types/three": "^0.182.0",
    "angularx-qrcode": "^21.0.5",
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-angular": "^0.562.0",
    "ng-recaptcha": "^13.2.1",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.0",
    "three": "^0.182.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.5",
    "@angular/cli": "^21.0.5",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.8",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "autoprefixer": "^10.4.23",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
