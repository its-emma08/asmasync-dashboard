# Configuración de Base de Datos
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/asmasync_db

# Configuración de Redis
REDIS_URL=redis://localhost:6379/0

# Seguridad JWT
# Generar con: openssl rand -hex 32
SECRET_KEY=change_me_in_production_please_generate_secure_key_123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=7

# Configuración del servidor
ENVIRONMENT=development
PROJECT_NAME="AsmaSync Backend"
CORS_ORIGINS=["http://localhost:4200", "http://localhost:8080"]

# Configuración de ML
ML_MODEL_PATH=app/ml/models/crisis_predictor.pkl
