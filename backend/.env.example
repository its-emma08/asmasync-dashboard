# ================================================
# AsmaSync Backend — Variables de Entorno
# ================================================
# Copia este archivo como `.env` y llena los valores
# NUNCA subas `.env` al repositorio (está en .gitignore)
# ================================================

# ── Base de Datos PostgreSQL ───────────────────────
# Local:    postgresql+asyncpg://postgres:postgres@localhost:5432/asmasync_db
# Render:   postgresql+asyncpg://user:pass@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/asmasync_db

# ── Seguridad JWT ──────────────────────────────────
# Genera un SECRET_KEY seguro con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UNO_GENERADO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Prefijo de la API ──────────────────────────────
# ⚠️  El frontend apunta a /api — NO cambies esto a /api/v1
API_V1_STR=/api

# ── Redis (requerido por config aunque no se usa activamente) ──
# Puedes dejar este valor aunque Redis no esté corriendo localmente
REDIS_URL=redis://localhost:6379/0

# ── CORS (origins permitidas) ─────────────────────
# Desarrollo local:
CORS_ORIGINS=["http://localhost:4200"]
# Producción (separar con coma si hay varios):
# CORS_ORIGINS=["https://tu-app.vercel.app","https://tu-dominio.com"]

# ── Entorno ───────────────────────────────────────
ENVIRONMENT=development
# En producción cambia a: ENVIRONMENT=production

# ── Email SMTP (2FA y notificaciones) ─────────────
# Si no configuras SMTP, los códigos 2FA aparecen en la consola del servidor
# Para Gmail con contraseña de aplicación:
#   1. Activa verificación en 2 pasos en tu cuenta Google
#   2. Ir a: myaccount.google.com/apppasswords
#   3. Crear contraseña → Tipo: "Correo" → copiar las 16 letras
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=tu_correo@gmail.com
SMTP_FROM_NAME=AsmaSync

# ================================================
# PARA DEPLOY EN RENDER:
# Agrega cada variable en: Dashboard → Service → Environment
# NO uses comillas en los valores en Render
# ================================================
